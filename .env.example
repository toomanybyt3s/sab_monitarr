# SABnzbd Monitor — Environment Variable Configuration
# Copy this file to .env and fill in your values before running docker-compose.
#
#   cp .env.example .env

# -----------------------------------------------------------------
# Required
# -----------------------------------------------------------------

# Full URL to your SABnzbd instance (no trailing slash)
SABMON_SABNZBD_URL=http://sabnzbd:8080/sabnzbd

# SABnzbd API key (found in SABnzbd → Config → General → API Key)
SABMON_SABNZBD_API_KEY=your-api-key-here

# -----------------------------------------------------------------
# Optional
# -----------------------------------------------------------------

# Port on the host to expose the web UI (container always uses 5959)
HOST_PORT=5959

# How often (in seconds) the UI polls for updates. Minimum: 2
SABMON_REFRESH_INTERVAL=5

# Set to true to enable verbose debug logging
SABMON_DEBUG=false

# Set to true to include client IP and User-Agent in request logs
SABMON_LOG_CLIENT_INFO=false
